{
  "name": "pulse-back",
  "version": "1.0.0",
  "description": "Backend Nest.js pour Pulse",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest",
